      },
      "targets": [
        {
          "datasource": "Observatorium",
          "expr": "node_memory_MemAvailable_bytes{cluster=\"$cluster\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Available Memory per Node",
      "type": "timeseries"
    },
    {
      "datasource": "Observatorium",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": "Observatorium",
          "expr": "machine_cpu_cores{cluster=\"$cluster\"}",
          "legendFormat": "{{ instance }} - total cores",
          "refId": "A"
        },
        {
          "datasource": "Observatorium",
          "expr": "sum(rate(node_cpu_seconds_total{mode=\"idle\", cluster=\"$cluster\"}[5m])) by (instance)",
          "legendFormat": "{{ instance }} - idle cores",
          "refId": "B"
        }
      ],
      "title": "Available CPU per Node",
      "type": "timeseries"
    }
